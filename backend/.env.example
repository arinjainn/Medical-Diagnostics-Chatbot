# Server configuration
PORT=5000

# Database connection
# Example local MongoDB: mongodb://localhost:27017/medbot
# Example MongoDB Atlas: mongodb+srv://<username>:<password>@cluster0.mongodb.net/medbot?retryWrites=true&w=majority
MONGODB_URL=your_mongodb_url

# Authentication Secrets (use strong random strings)
JWT_SECRET=your_jwt_secret
COOKIE_SECRET=your_cookie_secret

# Gemini API Key (Required for chat diagnostics)
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key

# Twilio Credentials (Required for SMS notifications)
# Get credentials from: https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Optional OpenAI configuration (commented out in current codebase)
# OPEN_AI_SECRET=your_open_ai_secret
# OPENAI_ORGANIZATION_ID=your_openai_organization_id
